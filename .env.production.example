# Compose-level production settings. Copy this file to .env on the VPS if you
# want docker compose to load these defaults automatically.

APP_PORT=80
APP_VERSION=production
BACKEND_ENV_FILE=./backend/.env.production

# Frontend values are baked into the Vite build at image build time.
VITE_API_URL=/api/v1
VITE_API_BASE_URL=/api/v1
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_PUBLIC_SUPABASE_ANON_KEY
VITE_SUPABASE_PUBLISHABLE_KEY=
