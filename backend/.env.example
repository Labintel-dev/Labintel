# LabIntel backend example environment variables
# Copy this file to `.env` and fill the values before running locally or deploying.

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_KEY=
SUPABASE_ANON_KEY=

# Database
DATABASE_URL=

# JWT
JWT_SECRET=

# Third-party APIs
GEMINI_API_KEY=

# Storage and frontend
PDF_STORAGE_BUCKET=pdfs
FRONTEND_URL=https://your-project.vercel.app

# Runtime
PORT=3001
NODE_ENV=production
PORT=3001

# Supabase — from Settings → API
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_KEY=eyJh...   # service_role key — server-side ONLY
SUPABASE_ANON_KEY=eyJh...      # anon public key

# Direct Postgres connection (used only by db/runMigrations.js)
# Format: postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres
DATABASE_URL=postgresql://postgres:YOUR_DB_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# Google Gemini — from aistudio.google.com
GEMINI_API_KEY=AIza...

# Fast2SMS — from fast2sms.com → API credentials
FAST2SMS_API_KEY=your_api_key_here

# Patient portal JWT secret — generate with: openssl rand -base64 48
# Must be at least 32 bytes
JWT_SECRET=your_64_char_random_secret_here

# Frontend URL for CORS (no trailing slash)
FRONTEND_URL=http://localhost:5173

# Must match the bucket name you create in Supabase Storage
PDF_STORAGE_BUCKET=pdfs
